<?xml version="1.0"?>
<ruleset name="TenderWatch">
    <description>PSR-12 + strict types</description>

    <file>src</file>
    <file>tests</file>

    <exclude-pattern>src/Api/*</exclude-pattern>
    <exclude-pattern>tests/Unit/EnvironmentTest.php</exclude-pattern>

    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg value="sp"/>

    <rule ref="PSR12"/>

    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="0"/>
        </properties>
    </rule>
</ruleset>
